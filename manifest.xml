<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══════════════════════════════════════════
       TEMEL BİLGİLER
       Bu bölümdeki değerleri kendi bilgilerinizle güncelleyin.
  ════════════════════════════════════════════ -->

  <!-- 1. Benzersiz ID — guidgenerator.com'dan yeni GUID üretin -->
  <Id>d15d3d5a-87fa-48f1-be49-1a76b8703e69</Id>

  <Version>1.0.0</Version>
  <ProviderName>KoZer</ProviderName>
  <DefaultLocale>tr-TR</DefaultLocale>
  <DisplayName DefaultValue="FreeBusy Sharer"/>
  <Description DefaultValue="Takviminizdeki boş zamanları bulun ve şirket dışındaki kişilerle kolayca paylaşın."/>

  <!-- 2. İkon URL'leri — github.com/alperberber80/freebusysharer yerine GitHub Pages URL'nizi yazın -->
  <!-- Örnek: https://kullaniciadi.github.io/freebusysharer/assets/icon-32.png -->
  <IconUrl DefaultValue="https://github.com/alperberber80/freebusysharer/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://github.com/alperberber80/freebusysharer/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/alperberber80/freebusysharer/support.html"/>

  <AppDomains>
    <AppDomain>https://github.com/alperberber80/freebusysharer</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <!-- 3. Taskpane URL — github.com/alperberber80/freebusysharer değiştirin -->
        <SourceLocation DefaultValue="https://github.com/alperberber80/freebusysharer/taskpane.html"/>
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Read"/>
  </Rule>

  <!-- ═══════════════════════════════════════════
       RİBBON BUTON TANIMLAMALARI (VersionOverrides)
  ════════════════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>

          <!-- Yeni E-posta Compose Ribbon -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="freebusyGroup.compose">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="composeButton">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>FreeBusySharerPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- E-posta Okuma Ribbon -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="freebusyGroup.read">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="readButton">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>FreeBusySharerPaneRead</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://github.com/alperberber80/freebusysharer/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://github.com/alperberber80/freebusysharer/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://github.com/alperberber80/freebusysharer/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://github.com/alperberber80/freebusysharer/commands.html"/>
        <bt:Url id="Taskpane.Url"  DefaultValue="https://github.com/alperberber80/freebusysharer/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"   DefaultValue="Toplantı Araçları"/>
        <bt:String id="ButtonLabel"  DefaultValue="Müsait Saatleri Paylaş"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonDesc"   DefaultValue="Takviminizdeki boş zamanları bulun ve şirket dışı kişilerle paylaşın."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
